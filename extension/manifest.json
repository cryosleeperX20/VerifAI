{
  "manifest_version": 3,
  "name": "VerifAI",
  "version": "1.0.0",
  "description": "AI-powered fact-checking Chrome extension to verify online claims instantly",

  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/verifai.png",
      "48": "icons/verifai.png",
      "128": "icons/verifai.png"
    }
  },

  "icons": {
    "16": "icons/verifai.png",
    "48": "icons/verifai.png",
    "128": "icons/verifai.png"
  },

  "background": {
    "service_worker": "background.js"
  }
}